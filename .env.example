# ─── Bootstrap Configuration ───
# These are the ONLY required env vars. All other settings are
# loaded from Azure App Configuration (key=AIAgent, label=ENVIRONMENT).
AZURE_APPCONFIG_ENDPOINT=https://<your-app-config>.azconfig.io
ENVIRONMENT=Development

# ─── LangChain SDK (read directly by the SDK, not via App Config) ───
# These variables are consumed by the LangChain/LangSmith SDK directly.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT="Dilcore AI Agent"

# Required for local LangGraph Studio
LANGGRAPH_ALLOW_CORS=true
