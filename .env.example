# OpenRouter Configuration (use double underscores for nested settings)
OPENROUTER__API_KEY=your_openrouter_api_key_here
OPENROUTER__BASE_URL=https://openrouter.ai/api/v1
OPENROUTER__MODEL=openai/gpt-oss-20b:free

# Embedding Model Configuration (via OpenRouter)
VECTOR_STORE__EMBEDDING_MODEL=openai/text-embedding-3-small

# MongoDB Configuration (LangGraph checkpointer persistence)
MONGODB__CONNECTION_STRING=mongodb://localhost:27017
MONGODB__DB_NAME=langgraph_checkpoints

# Vector Store Configuration
VECTOR_STORE__BASE_PATH=./data/vector_store
VECTOR_STORE__METADATA_INDEX_NAME=metadata_index
VECTOR_STORE__DATA_INDEX_NAME=data_index

# Application Settings
APP_NAME="AI Template Agent"
APP_DEBUG=false
LOG_LEVEL=INFO
# Comma-separated allowed origins; use ["*"] for dev, explicit origins for prod
CORS_ORIGINS=["*"]

# Azure Telemetry Configuration
AZURE_APPLICATION_INSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...;LiveEndpoint=...

# LangSmith Tracing (Debugging Agents)
# https://docs.smith.langchain.com/
# Set to true and provide LANGCHAIN_API_KEY to enable tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT="Dilcore AI Agent"

# Auth0 Configuration
AUTH0__DOMAIN=your_auth0_domain
AUTH0__CLIENT_ID=your_auth0_api_doc_client_id
AUTH0__CLIENT_SECRET=your_auth0_api_doc_client_secret
AUTH0__AUDIENCE=your_auth0_audience
