# OpenRouter Configuration (use double underscores for nested settings)
OPENROUTER__API_KEY=your_openrouter_api_key_here
OPENROUTER__BASE_URL=https://openrouter.ai/api/v1
OPENROUTER__MODEL=openai/gpt-oss-20b:free

# Embedding Model Configuration (via OpenRouter)
VECTOR_STORE__EMBEDDING_MODEL=openai/text-embedding-3-small

# Vector Store Configuration
VECTOR_STORE__BASE_PATH=./data/vector_store
VECTOR_STORE__METADATA_INDEX_NAME=metadata_index
VECTOR_STORE__DATA_INDEX_NAME=data_index

# Application Settings
APP_NAME="AI Template Agent"
APP_DEBUG=false
LOG_LEVEL=INFO

# LangSmith Tracing (Debugging Agents)
# https://docs.smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT="Dilcore AI Agent"
